{"claim_type": "measurement", "line_end": 343, "line_start": 343, "page_hint": null, "section": "Ornl Dwg. 69-10965", "text": "Load in compression to a stress level greater than in Step 2 and unload."}
{"claim_type": "measurement", "line_end": 344, "line_start": 344, "page_hint": null, "section": "Ornl Dwg. 69-10965", "text": "Heat treat at $3000^{\\circ}C$ for 60 minutes."}
